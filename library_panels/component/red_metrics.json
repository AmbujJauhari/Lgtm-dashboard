{
  "uid": "collops-cmp-red-metrics",
  "name": "[Component] RED metrics",
  "kind": 1,
  "model": {
    "type": "timeseries",
    "title": "[Component] RED metrics",
    "description": "Request rate, error rate, and latency percentiles for the selected service and instance.",
    "datasource": { "type": "prometheus", "uid": "__MIMIR__" },
    "targets": [
      {
        "datasource": { "type": "prometheus", "uid": "__MIMIR__" },
        "expr": "sum(rate(http_server_request_duration_seconds_count{__APP_SELECTOR__,service_name=\"$service_name\",instance=~\"$instance\"}[$__rate_interval]))",
        "legendFormat": "Request rate (rps)",
        "refId": "A"
      },
      {
        "datasource": { "type": "prometheus", "uid": "__MIMIR__" },
        "expr": "sum(rate(http_server_request_duration_seconds_count{__APP_SELECTOR__,service_name=\"$service_name\",instance=~\"$instance\",http_response_status_code=~\"5..\"}[$__rate_interval]))",
        "legendFormat": "Error rate (rps)",
        "refId": "B"
      },
      {
        "datasource": { "type": "prometheus", "uid": "__MIMIR__" },
        "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{__APP_SELECTOR__,service_name=\"$service_name\",instance=~\"$instance\"}[$__rate_interval])))",
        "legendFormat": "p99 latency",
        "refId": "C"
      },
      {
        "datasource": { "type": "prometheus", "uid": "__MIMIR__" },
        "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{__APP_SELECTOR__,service_name=\"$service_name\",instance=~\"$instance\"}[$__rate_interval])))",
        "legendFormat": "p95 latency",
        "refId": "D"
      },
      {
        "datasource": { "type": "prometheus", "uid": "__MIMIR__" },
        "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{__APP_SELECTOR__,service_name=\"$service_name\",instance=~\"$instance\"}[$__rate_interval])))",
        "legendFormat": "p50 latency",
        "refId": "E"
      }
    ],
    "options": {
      "tooltip": { "mode": "multi", "sort": "desc" },
      "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] }
    },
    "fieldConfig": {
      "defaults": {
        "color": { "mode": "palette-classic" },
        "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" }
      },
      "overrides": [
        {
          "matcher": { "id": "byName", "options": "Error rate (rps)" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
        },
        {
          "matcher": { "id": "byRegexp", "options": ".*latency.*" },
          "properties": [{ "id": "unit", "value": "s" }]
        },
        {
          "matcher": { "id": "byRegexp", "options": ".*rate.*" },
          "properties": [{ "id": "unit", "value": "reqps" }]
        }
      ]
    }
  }
}
